# DistillStack Configuration
# Copy this file to .env and fill in the values.

# LiteLLM API key (required for synthesis and quality scoring)
DISTILL_LITELLM_API_KEY=sk-your-api-key-here

# Model selections
DISTILL_TEACHER_MODEL=gpt-4o-mini
DISTILL_CRITIC_MODEL=gpt-4o-mini
DISTILL_VLM_MODEL=deepseek/deepseek-ocr-2

# Processing thresholds
DISTILL_VLM_CONFIDENCE_THRESHOLD=0.85
DISTILL_MAX_CHUNK_TOKENS=1024

# Output
DISTILL_OUTPUT_DIR=output

# Logging
DISTILL_LOG_LEVEL=INFO
